# ----------------------------------------------------------------------------
# Supabase
# ----------------------------------------------------------------------------
# Found in Supabase project settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key - SERVER SIDE ONLY. Never expose to the browser.
# Used for tenant onboarding and the WhatsApp webhook (bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ----------------------------------------------------------------------------
# Meta WhatsApp Cloud API
# ----------------------------------------------------------------------------
WHATSAPP_TOKEN=your-permanent-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
# Any string you choose - must match what you configure in the Meta App
# webhook setup screen.
WHATSAPP_VERIFY_TOKEN=choose-a-random-verify-token

# ----------------------------------------------------------------------------
# App
# ----------------------------------------------------------------------------
# Used to build absolute URLs (e.g. password reset redirect)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
